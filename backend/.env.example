NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://127.0.0.1:27017/dishdirect

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

CORS_ORIGIN=https://dish-direct-web-app.onrender.com
FRONTEND_URL=https://dish-direct-web-app.onrender.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@example.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://dish-direct-web-app.onrender.com/auth/google/callback

